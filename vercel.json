{

  "headers": [

    {

      "source": "/(.*)",

      "headers": [

        {

          "key": "X-Content-Type-Options",

          "value": "nosniff"

        },

        {

          "key": "Referrer-Policy",

          "value": "strict-origin-when-cross-origin"

        },

        {

          "key": "X-Frame-Options",

          "value": "DENY"

        },

        {

          "key": "Permissions-Policy",

          "value": "camera=(), microphone=(), geolocation=()"

        }

      ]

    }

  ],

  "redirects": [

    {

      "source": "/admin",

      "destination": "/admin/",

      "permanent": true

    }

  ],

  "rewrites": [

    {

      "source": "/t/:track",

      "destination": "/api/tracks?share=:track"

    },

    {

      "source": "/a/:album",

      "destination": "/api/tracks?albumShare=:album"

    }

  ]

}
